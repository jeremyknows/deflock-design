{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/actions/**",
              "components/data/**",
              "components/feedback/**",
              "components/forms/**",
              "components/navigation/**",
              "components/overlay/**",
              "components/surfaces/**",
              "register/**",
              "scripts/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Archivo Black|Oswald|Space Mono))/i]",
        "message": "Font not provided by the design system. Available: Archivo Black, Oswald, Space Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|tilt|selected|style|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, tilt, selected, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:stamp|kicker|solid|accent|chip)$/]",
        "message": "<Badge> variant must be one of 'stamp' | 'kicker' | 'solid' | 'accent' | 'chip'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|font|tilt|iconOnly|disabled|href|target|onClick|type|style|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, font, tilt, iconOnly, disabled, href, target, onClick, type, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|accent|quiet)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'accent' | 'quiet'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg|xl)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='font'] > Literal[value!=/^(?:meta|label)$/]",
        "message": "<Button> font must be one of 'meta' | 'label'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit)$/]",
        "message": "<Button> type must be one of 'button' | 'submit'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FooterStrip'] > JSXAttribute > JSXIdentifier[name!=/^(?:contactEmail|extra|style|key|ref|className|style|children)$/]",
        "message": "<FooterStrip> doesn't accept that prop. Declared props: contactEmail, extra, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FormRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|htmlFor|error|hint|children|style|key|ref|className|style|children)$/]",
        "message": "<FormRow> doesn't accept that prop. Declared props: label, htmlFor, error, hint, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|invalid|placeholder|value|onChange|id|type|inputMode|maxLength|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: size, invalid, placeholder, value, onChange, id, type, inputMode, maxLength, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:lg|xl)$/]",
        "message": "<Input> size must be one of 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Metric'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|label|value|sub|wash|nudge|style|key|ref|className|style|children)$/]",
        "message": "<Metric> doesn't accept that prop. Declared props: eyebrow, label, value, sub, wash, nudge, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Metric'] > JSXAttribute[name.name='wash'] > Literal[value!=/^(?:none|accent|red)$/]",
        "message": "<Metric> wash must be one of 'none' | 'accent' | 'red'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Panel'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|surface|halftone|raised|pad|as|style|children|key|ref|className|style|children)$/]",
        "message": "<Panel> doesn't accept that prop. Declared props: variant, surface, halftone, raised, pad, as, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Panel'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:card|raised|stamp|accent|empty)$/]",
        "message": "<Panel> variant must be one of 'card' | 'raised' | 'stamp' | 'accent' | 'empty'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Panel'] > JSXAttribute[name.name='surface'] > Literal[value!=/^(?:card|quiet|bright|wash-ink|accent|accent-strong|paper)$/]",
        "message": "<Panel> surface must be one of 'card' | 'quiet' | 'bright' | 'wash-ink' | 'accent' | 'accent-strong' | 'paper'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sheet'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|onClose|title|width|children|style|key|ref|className|style|children)$/]",
        "message": "<Sheet> doesn't accept that prop. Declared props: open, onClose, title, width, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SiteHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:tabs|activeHref|onNavigate|homeHref|style|key|ref|className|style|children)$/]",
        "message": "<SiteHeader> doesn't accept that prop. Declared props: tabs, activeHref, onNavigate, homeHref, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:date|title|note|valueLabel|value|href|linkLabel|style|key|ref|className|style|children)$/]",
        "message": "<StatRow> doesn't accept that prop. Declared props: date, title, note, valueLabel, value, href, linkLabel, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|fixed|icon|role|style|children|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: variant, fixed, icon, role, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:warning|alert|neutral)$/]",
        "message": "<Toast> variant must be one of 'warning' | 'alert' | 'neutral'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
