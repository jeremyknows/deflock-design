{
  "$schema": "deflock-web-tokens-source",
  "$description": "Three-tier web-UI token definitions for DeFlock Design. TIER 1 primitives resolve from ../tokens.json (machine truth, locked 2026-07-11) via {json:path} pointers; web-only physical values carry a 'src' provenance note naming the src/ file they were ratified from. TIER 2 semantic and TIER 3 component tokens reference tier 1/2 via {var} pointers. scripts/generate-tokens.mjs compiles this file + tokens.json into tokens/generated/df-tokens.css. NEVER hand-edit the generated CSS; never re-transcribe tokens.json values here.",
  "tier1": {
    "color-paper": { "value": "{json:color.paper.value}" },
    "color-ink": { "value": "{json:color.ink.value}" },
    "color-red": { "value": "{json:color.red.value}" },
    "color-gadsden": { "value": "{json:color.gadsden.value}" },
    "font-slam": { "value": "{json:type.slam.family}" },
    "font-label": { "value": "{json:type.label.family}" },
    "font-meta": { "value": "{json:type.meta.family}" },
    "weight-label-body": { "value": "{json:type.label.body.weight}", "note": "Oswald 400; served from the upstream variable font (assets/fonts/oswald-variable.ttf, OFL) — gap closed 2026-07-14" },
    "weight-label": { "value": "500" },
    "weight-label-strong": { "value": "700" },
    "weight-meta": { "value": "400" },
    "weight-meta-strong": { "value": "700" },
    "tracking-slam": { "value": "{json:type.slam.letterSpacing}" },
    "tracking-label": { "value": "{json:type.label.letterSpacing}" },
    "tracking-meta": { "value": "{json:type.meta.letterSpacing.0}" },
    "tracking-meta-wide": { "value": "{json:type.meta.letterSpacing.1}" },
    "leading-slam": { "value": "{json:type.slam.lineHeight.0}" },
    "leading-slam-max": { "value": "{json:type.slam.lineHeight.1}" },
    "space-unit": { "value": "{json:layout.baseUnit}" },
    "chrome-margin": { "value": "{json:layout.chromeMargin}", "note": "4.5% of frame short side; page gutters" },
    "stroke-hairline": { "value": "1.5px", "note": "reg-mark stroke; THE standard border. src: tokens.json texture.regMarks + profile.module.css" },
    "stroke-heavy": { "value": "3px", "note": "2x hairline; emphasis panels + stamp border weight. src: globals.css .zip-widget" },
    "radius-none": { "value": "0", "note": "riso has no rounded corners; avatar is the sole exception" },
    "radius-avatar": { "value": "999px" },
    "halftone-image": { "value": "radial-gradient(circle, rgba(20,16,10,.14) 1.1px, transparent 1.2px)", "lockRef": "tokens.json texture.halftone.css" },
    "halftone-size": { "value": "9px 9px", "lockRef": "tokens.json texture.halftone.pitch" },
    "halftone-red": { "value": "{json:texture.halftone.redVariant}" },
    "grain-opacity": { "value": "{json:texture.grain.overlayOpacity.0}" },
    "grain-opacity-max": { "value": "{json:texture.grain.overlayOpacity.1}" },
    "misreg-shadow": { "value": ".045em .03em 0 #d92b1c", "lockRef": "tokens.json texture.misregistration.css", "note": "scope: display type + villain glyph ONLY; red down-right (share-card route's up-left offset is drift)" },
    "misreg-peak": { "value": ".075em", "lockRef": "tokens.json texture.misregistration.peak (motion pulse / loud mode only)" },
    "stamp-inset": { "value": "inset 0 0 0 2px #f2ede3, inset 0 0 0 4.5px #d92b1c", "lockRef": "tokens.json texture.stamp.css" },
    "stamp-inset-ink": { "value": "inset 0 0 0 1.5px #f2ede3, inset 0 0 0 4px #14100a", "note": "ink stamp ring for UI selected-states. src: globals.css .site-nav-link[data-active]" },
    "tilt-stamp-min": { "value": "{json:texture.stamp.rotate.min}", "fallback": "-4deg" },
    "tilt-stamp-max": { "value": "4deg" },
    "tilt-block": { "value": "-1.5deg", "note": "register rule R1: content-block tilt. src: register.json" },
    "ease-press": { "value": "{json:motion.eases.PRESS.curve}" },
    "ease-reward": { "value": "{json:motion.eases.REWARD.curve}" },
    "ease-plate": { "value": "linear" },
    "dur-press": { "value": "150ms" },
    "dur-press-max": { "value": "300ms" },
    "dur-reward": { "value": "400ms" },
    "dur-ui": { "value": "120ms", "note": "shipped UI micro-interaction duration. src: globals.css (all transitions)" }
  },
  "tier2": {
    "surface-page": { "value": "{color-paper}" },
    "surface-card": { "value": "color-mix(in srgb, {color-paper} 92%, white)", "note": "src: globals.css .donations-panel" },
    "surface-card-quiet": { "value": "color-mix(in srgb, {color-paper} 94%, white)", "note": "src: profile.module.css panels" },
    "surface-card-bright": { "value": "color-mix(in srgb, {color-paper} 86%, white)", "note": "src: profile.module.css .identityCard" },
    "surface-inverse": { "value": "{color-ink}" },
    "surface-wash-ink": { "value": "color-mix(in srgb, {color-ink} 8%, {color-paper})", "note": "src: globals.css .real-project, .why-link" },
    "surface-wash-accent": { "value": "color-mix(in srgb, {color-gadsden} 14%, {color-paper})", "note": "src: globals.css .zip-panel, .donations-data-warning" },
    "surface-wash-accent-strong": { "value": "color-mix(in srgb, {color-gadsden} 18%, {color-paper})", "note": "src: globals.css .donations-legacy" },
    "surface-wash-red": { "value": "color-mix(in srgb, {color-red} 10%, {color-paper})", "note": "src: globals.css .donations-metric-card:nth-child(3)" },
    "surface-backdrop": { "value": "color-mix(in srgb, {color-ink} 48%, transparent)", "note": "src: profile.module.css .sheetBackdrop" },
    "text-primary": { "value": "{color-ink}" },
    "text-inverse": { "value": "{color-paper}" },
    "text-accent": { "value": "{color-red}", "note": "large/bold type + non-text UI only on paper; NEVER on ink grounds" },
    "text-muted": { "value": "color-mix(in srgb, {color-ink} 72%, {color-paper})", "note": "src: globals.css .zip-attribution" },
    "border-default": { "value": "{stroke-hairline} solid {color-ink}" },
    "border-heavy": { "value": "{stroke-heavy} solid {color-ink}" },
    "border-accent": { "value": "{stroke-hairline} solid {color-red}" },
    "border-dashed": { "value": "{stroke-hairline} dashed {color-ink}", "note": "empty states. src: profile.module.css .emptyState" },
    "focus-ring": { "value": "2px solid {color-ink}", "note": "src: globals.css :focus-visible; on ink surfaces flip to paper via --df-focus-ring-inverse" },
    "focus-ring-inverse": { "value": "2px solid {color-paper}" },
    "focus-offset": { "value": "2px" },
    "shadow-hard-sm": { "value": "calc({space-unit} * 0.35) calc({space-unit} * 0.35) 0 {color-ink}", "note": "src: globals.css .donations-link-accent" },
    "shadow-hard-md": { "value": "calc({space-unit} * 0.75) calc({space-unit} * 0.75) 0 {color-ink}", "note": "src: globals.css .zip-widget, .donations-legacy" },
    "shadow-hover": { "value": "calc({space-unit} * 0.3) calc({space-unit} * 0.3) 0 color-mix(in srgb, {color-ink} 36%, transparent)", "note": "src: library.module.css .filter:hover" },
    "press-scale": { "value": "0.96", "note": "universal press affordance. src: every interactive element in src/" },
    "press-scale-icon": { "value": "0.92", "note": "src: profile.module.css .shareArrow:active" },
    "hover-lift": { "value": "translate(-1px, -1px)", "note": "src: library.module.css hover states" },
    "control-h-sm": { "value": "calc({space-unit} * 5)", "note": "40px. src: profile .signOutButton" },
    "control-h-md": { "value": "calc({space-unit} * 5.5)", "note": "44px tap-target floor. src: globals .why-cta, nav links" },
    "control-h-lg": { "value": "calc({space-unit} * 6)", "note": "48px. src: profile .inputRow" },
    "control-h-xl": { "value": "calc({space-unit} * 7)", "note": "56px. src: globals .zip-form" },
    "type-slam": { "value": "400 1em/{leading-slam} {font-slam}", "transform": "uppercase" },
    "size-title-page": { "value": "clamp(1.75rem, 4vw, 3rem)", "note": "operator-ratified page-title scale 2026-07-12 (profile/library/raid parity)" },
    "size-title-hero": { "value": "clamp(calc({space-unit} * 5.8), 12vw, calc({space-unit} * 13.5))", "note": "homepage hero only. src: globals .why-hero h1" },
    "size-meta-sm": { "value": "calc({space-unit} * 1.45)", "note": "11.6px chrome meta. src: profile.module.css" },
    "size-meta": { "value": "calc({space-unit} * 1.5)", "note": "12px control meta. src: globals donations links" },
    "size-meta-lg": { "value": "16px", "lockRef": "tokens.json type.meta.min" },
    "size-label-body": { "value": "clamp(calc({space-unit} * 1.9), 1.55vw, calc({space-unit} * 2.4))", "note": "src: profile .heroCopy" },
    "leading-body": { "value": "1.25" },
    "z-header": { "value": "10" },
    "z-grain": { "value": "20" },
    "z-nav-mobile": { "value": "30" },
    "z-sheet": { "value": "40", "note": "known production gap: ships as 30, ties mobile nav; sheet must win" },
    "bp-site": { "value": "720px", "note": "header collapses to bottom tab bar. src: globals.css" },
    "bp-panel": { "value": "860px", "note": "two-column panels stack. src: profile.module.css" },
    "bp-tight": { "value": "430px", "note": "register floor: chrome margin holds, slam floors clamp, texture budgets unchanged" }
  },
  "tier3": {
    "btn-border": { "value": "{border-default}" },
    "btn-radius": { "value": "{radius-none}" },
    "btn-font": { "value": "{font-meta}" },
    "btn-weight": { "value": "{weight-meta-strong}" },
    "btn-tracking": { "value": "{tracking-meta}" },
    "btn-size": { "value": "{size-meta}" },
    "btn-primary-bg": { "value": "{surface-inverse}" },
    "btn-primary-fg": { "value": "{text-inverse}" },
    "btn-secondary-bg": { "value": "{color-paper}" },
    "btn-secondary-fg": { "value": "{text-primary}" },
    "btn-accent-bg": { "value": "{color-gadsden}" },
    "btn-accent-fg": { "value": "{text-primary}" },
    "btn-accent-shadow": { "value": "{shadow-hard-sm}" },
    "btn-accent-tilt": { "value": "{tilt-block}" },
    "btn-quiet-bg": { "value": "{surface-wash-ink}" },
    "btn-disabled-opacity": { "value": "0.55", "note": "src: profile .signInButton:disabled; sheet buttons ship 0.45 (gap: unify at 0.55)" },
    "input-border": { "value": "{border-default}" },
    "input-bg": { "value": "{color-paper}" },
    "input-h": { "value": "{control-h-lg}" },
    "input-font": { "value": "{font-label}" },
    "panel-border": { "value": "{border-default}" },
    "panel-bg": { "value": "{surface-card}" },
    "panel-pad": { "value": "calc({space-unit} * 3)" },
    "panel-raised-border": { "value": "{border-heavy}" },
    "panel-raised-shadow": { "value": "{shadow-hard-md}" },
    "panel-stamp-border": { "value": "{border-accent}" },
    "panel-stamp-shadow": { "value": "{stamp-inset}" },
    "badge-border": { "value": "{border-default}" },
    "badge-font": { "value": "{font-meta}" },
    "badge-size": { "value": "{size-meta-sm}" },
    "badge-tilt": { "value": "{tilt-stamp-min}" },
    "nav-h": { "value": "{control-h-md}" },
    "nav-active-ring": { "value": "{stamp-inset-ink}" },
    "nav-active-bg": { "value": "color-mix(in srgb, {color-ink} 8%, transparent)" },
    "footer-font": { "value": "{font-meta}" },
    "footer-ticker-font": { "value": "{font-meta}", "note": "quiet wordmark = Space Mono 700 per Identity law; ships as slam family (known production gap P1-6)" },
    "sheet-w": { "value": "calc({space-unit} * 80)" },
    "sheet-pad": { "value": "calc({space-unit} * 3)" },
    "stat-row-border": { "value": "{border-default}" },
    "stat-value-font": { "value": "{font-slam}" },
    "stat-label-font": { "value": "{font-meta}" },
    "toast-border": { "value": "{border-default}" },
    "toast-bg": { "value": "{surface-wash-accent}" },
    "avatar-size": { "value": "calc({space-unit} * 9)" }
  }
}
